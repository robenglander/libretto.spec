grammar com.robenglander.libretto.spec.LibrettoProjectProfile with org.eclipse.xtext.common.Terminals

hidden(WS, ML_COMMENT, SL_COMMENT)

generate librettoProjectProfile "http://www.robenglander.com/libretto/spec/LibrettoProjectProfile"

/**
 * Libretto <b>project profile</b> — declarative tooling configuration (not the `.libretto` spec language).
 * <p>
 * File extension: {@code .lpp}. Binds at build/CLI time. Spec metadata {@code project_profile_id} should match
 * this file's profile name when using {@code --project-profile} (see surface generator).
 * See {@code docs/DESIGN-SurfaceProfileConfigXtext.md} in the Libretto repository.
 * <p>
 * Principle: <b>config, not a programming language</b> — fixed statement forms, explicit names and types,
 * optional scoped blocks; no patterns, conditionals, or executable logic in the grammar.
 */

ProjectProfile:
	{ProjectProfile}
	'profile' name=ValidID '{'
		(
		projects+=ProjectBlock
		|
		llmProviders+=LlmProvidersBlock
		|
		surfaces+=SurfaceBlock
		)*
	'}';

ProjectBlock:
	{ProjectBlock} 
	'project' '{'
		(
			('rootDir' rootDir+=STRING)
			|
			(modules+=ModulesBlock)
			|
			(gens+=GenBlock)
		)*
	'}';

ModulesBlock:
	{ModulesBlock} 
	'modules' '{'
		modules+=ProjectModule*
	'}';

ProjectModule:
	'module' name=ValidID '{'
		(
			('dir' dirs+=STRING)
			|
			('specDir' specDirs+=STRING)
			|
			('testDir' testDirs+=STRING)
			|
			('mainDir' mainDirs+=STRING)
			|
			('basePackage' basePackages+=STRING)
		)*
	'}';

GenBlock:
	{GenBlock} 
	'gen' '{'
		(
			('initialInstruction' initialInstructions+=STRING)
			|
			('maxRetries' maxRetries+=INT)
			|
			('parseCheck' parseChecks+=('true' | 'false'))
			|
			('defaultCorrection' defaultCorrections+=STRING)
			|
			(remediations+=GenRemediationRules)
			|
			(modelUsages+=GenUsageBlock)
		)*
	'}';

GenRemediationRules:
	{GenRemediationRules} 
	'rules' '{'
		(
			(patternRules+=GenPatternRemediationRule)
			(defaultRemediations+=GenDefaultRemediationRule)
		)*
	'}';

GenPatternRemediationRule:
	{GenPatternRemediationRule} 
	'rule' '{'
		(
			('pattern' patterns+=STRING)
			|
			('code' codes+=STRING)
			|
			('correction' corrections+=STRING)
		)*
	'}';

GenDefaultRemediationRule:
	{GenDefaultRemediationRule} 
	'default' '{'
		(
			('code' codes+=STRING)
			|
			('correction' correction+=STRING)
		)*
	'}';

LlmProvidersBlock:
	{LlmProvidersBlock} 
	'llmProviders' '{'
		providers+=NamedLlmProvider*
	'}';

NamedLlmProvider:
	'provider' name=ValidID '{'
		(
			('kind' kinds+=('local' | 'openai' | 'ollama'))
			|
			('localModelPath' localModelPaths+=STRING)
			|
			('model' models+=STRING)
			|
			('endpoint' endpoints+=STRING)
		)*
	'}';

GenUsageBlock:
	{GenUsageBlock} 
	'modelUsage' '{'
		(
			('primary' primaryProviders+=STRING)
			|
			('secondary' secondaryProviders+=STRING)
			|
			(escalations+=GenEscalationBlock)
		)*
	'}';

GenEscalationBlock:
	{GenEscalationBlock} 
	'escalation' '{'
		(
			('enabled' enableds+=('true' | 'false'))
			|
			('escalateAtRetries' escalateAtRetries+=INT)
		)*
	'}';

SurfaceBlock:
	{SurfaceBlock} 
	'surface' '{'
		elements+=SurfaceElement*
	'}';

SurfaceElement:
	ScopedSurface | SurfaceRule;

ScopedSurface:
	'for' ('module' moduleId=STRING | 'spec' specId=STRING) '{' rules+=SurfaceRule* '}';

SurfaceRule:
	ReturnTypeRule | ParamTypeRule | RecordSelfReturnRule | MethodOverrideRule;

ReturnTypeRule:
	'returnType' 'method' name=ID 'as' javaType=JavaType (';')?;

ParamTypeRule:
	'paramType' 'name' paramName=ID 'as' javaType=JavaType (';')?;

RecordSelfReturnRule:
	'recordSelfReturn' methods+=ID (',' methods+=ID)* (';')?;

MethodOverrideRule:
	'methodOverride' signature=OperationSignature 'returns' javaType=JavaType (';')?;

JavaType:
	PrimitiveType | QualifiedName;

QualifiedName:
	segments+=ID ('.' segments+=ID)*;

PrimitiveType:
	kind=('boolean' | 'int' | 'long' | 'double' | 'float' | 'short' | 'byte' | 'char' | 'void');

OperationSignature:
	name=ID '(' (params+=TypedParam (',' params+=TypedParam)*)? ')';

TypedParam:
	type=JavaType paramName=ID;
	
ValidID:
	ID ( ('.' | '-' | '_') ID)*;


