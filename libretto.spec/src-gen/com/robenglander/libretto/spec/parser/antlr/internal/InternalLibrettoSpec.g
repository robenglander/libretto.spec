RULE_TEXT_BLOCK : '"""' (~('"')|'"' ~('"')|'"' '"' ~('"'))* '"""';

RULE_BEHAVIOR_ID : 'B-' '0'..'9' '0'..'9' '0'..'9';

RULE_ACCEPTANCE_TEST_ID : 'AT-' '0'..'9' '0'..'9' '0'..'9';

RULE_IMPLEMENTATION_DIRECTIVE_ID : 'ID-' '0'..'9' '0'..'9' '0'..'9';

RULE_REF_ID : 'REF-' '0'..'9' '0'..'9' '0'..'9';

RULE_OOS_ID : 'OOS-' '0'..'9' '0'..'9' '0'..'9';

RULE_LIBRETTO_ID : '^'? ('a'..'z'|'A'..'Z'|'_') ('a'..'z'|'A'..'Z'|'_'|'0'..'9'|'-'|'\\')*;

RULE_ID : '^'? ('a'..'z'|'A'..'Z'|'_') ('a'..'z'|'A'..'Z'|'_'|'0'..'9')*;

RULE_INT : ('0'..'9')+;

RULE_STRING : ('"' ('\\' .|~(('\\'|'"')))* '"'|'\'' ('\\' .|~(('\\'|'\'')))* '\'');

RULE_ML_COMMENT : '/*' ( options {greedy=false;} : . )*'*/';

RULE_SL_COMMENT : '//' ~(('\n'|'\r'))* ('\r'? '\n')?;

RULE_WS : (' '|'\t'|'\r'|'\n')+;

RULE_ANY_OTHER : .;
